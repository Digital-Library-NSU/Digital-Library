ES_URL=http://localhost:9200
ES_USER=
ES_PASS=
ES_INDEX_META=books_meta
ES_INDEX_CONTENT=books_content

# PG для «гидратации» карточек (тот же DSN, что ты давала импортеру)
PG_DSN=postgresql://libuser:libpass@localhost:5432/library

# Энкодер для семантики
EMBED_MODEL=./models/bge-m3     # или BAAI/bge-m3, если из хаба
EMBED_DEVICE=auto               # auto|cpu|cuda
EMBED_NORMALIZE=true            # для cosine лучше true
EMBED_ADD_QUERY_PREFIX=true     # для bge-m3 полезно